{
  "name": "monaco-unocss",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.10.0",
  "description": "UnoCSS integration for Monaco editor",
  "author": {
    "name": "Ilyal",
    "url": "https://github.com/ilyaliao"
  },
  "license": "MIT",
  "homepage": "https://github.com/ilyaliao/monaco-unocss#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilyaliao/monaco-unocss.git"
  },
  "bugs": "https://github.com/ilyaliao/monaco-unocss/issues",
  "keywords": [
    "monaco-editor",
    "monaco",
    "unocss",
    "intellisense",
    "autocomplete",
    "language-server",
    "worker"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./unocss.worker": {
      "types": "./dist/unocss.worker.d.mts",
      "import": "./dist/unocss.worker.mjs",
      "require": "./dist/unocss.worker.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "play": "nr -C examples/vite dev",
    "lint": "eslint .",
    "prepublishOnly": "nr build",
    "release": "bumpp -r",
    "start": "esno src/index.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "@unocss/autocomplete": ">=66.7.5",
    "@unocss/core": ">=66.7.5",
    "monaco-editor": ">=0.55.1"
  },
  "dependencies": {
    "@colordx/core": "^5.5.0",
    "@ctrl/tinycolor": "^4.2.0",
    "magic-string": "^1.0.0",
    "monaco-languageserver-types": "^0.4.1",
    "monaco-types": "^0.1.2",
    "monaco-worker-manager": "^2.0.1",
    "prettier": "^3.9.5",
    "vscode-languageserver-protocol": "^3.18.2",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@antfu/ni": "^30.2.0",
    "@antfu/utils": "^9.3.0",
    "@types/node": "^26.1.0",
    "@unocss/autocomplete": "^66.7.5",
    "@unocss/core": "^66.7.5",
    "@unocss/transformer-variant-group": "^66.7.5",
    "bumpp": "^11.1.0",
    "eslint": "^10.6.0",
    "esno": "^4.8.0",
    "lint-staged": "^17.0.8",
    "pnpm": "^11.10.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "unocss": "^66.7.5",
    "vite": "^6.3.5",
    "vitest": "^4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
